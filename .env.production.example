# Production environment variables
# Copy to .env.production and fill in real values

# Domain
DOMAIN=pii-gateway.example.com

# Database (use a strong random password)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis (use a strong random password)
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT Secret (minimum 64 characters, randomly generated)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64

# AES-256-GCM encryption key (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# Container registry
REGISTRY=ghcr.io
IMAGE_PREFIX=your-org/piigateway
VERSION=latest

# LLM Backend (disabled, ollama, or mistral)
LLM_BACKEND=disabled
MISTRAL_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434

# NER Configuration
NER_MODEL_NAME=Davlan/bert-base-multilingual-cased-ner-hrl
NER_DEVICE=cpu
LAYER2_ENABLED=true
